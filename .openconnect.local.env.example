# 本文件仅供本地复制为 .openconnect.local.env 使用，不要提交真实域名或凭据。

# 可选：quick / named / endpoint
OPENCONNECT_MODE=named

# 如果使用命名 Tunnel，建议填写下面两个值
OPENCONNECT_TUNNEL_NAME=YOUR_TUNNEL_NAME_OR_UUID
OPENCONNECT_HOSTNAME=codex.example.com

# 如果你已经有固定公网 WebSocket 地址，也可以改成 endpoint 模式：
# OPENCONNECT_MODE=endpoint
# OPENCONNECT_ENDPOINT=wss://codex.example.com

# 其他可选默认值
# OPENCONNECT_CWD=/path/to/your/project
# OPENCONNECT_LISTEN_HOST=127.0.0.1
# OPENCONNECT_LISTEN_PORT=9000
# OPENCONNECT_CLOUDFLARED_CONFIG=/Users/YOU/.cloudflared/config.yml

# 如果你本地需要固定透传认证头，也可以写在这里
# OPENCONNECT_BEARER_TOKEN=
# OPENCONNECT_CF_ACCESS_CLIENT_ID=
# OPENCONNECT_CF_ACCESS_CLIENT_SECRET=
